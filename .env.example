# All optional. The site is fully functional with an empty .env —
# form submissions are logged to stdout instead of emailed.

# SMTP relay for form submissions.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Where form submissions are delivered.
MAIL_TO=

# Canonical origin used in metadata, sitemap and robots.
NEXT_PUBLIC_SITE_URL=https://www.avangardexpresscorp.com

# Google Search Console verification token (renders a <meta> tag when set).
GOOGLE_SITE_VERIFICATION=

# Meta (Facebook) pixel — injected only when set. No tracking by default.
META_PIXEL_ID=
